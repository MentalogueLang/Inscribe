import core.bool
import shared.json
import io.console

fn print_result(label: string, source: string) {
    let result = parse_document(source)
    write_line_string(label)
    write_line_int(bool_to_int(result_ok(result)))
    write_line_int(kind_code(result_kind(result)))
}

fn main() -> int {
    print_result("object", "{\"a\":1,\"b\":2}")
    print_result("array", "[null,false,true]")
    print_result("invalid", "[1,2")
    0
}
